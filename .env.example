# --- MongoDB ---
# Your MongoDB Atlas (or any MongoDB) connection string.
# When unset, the site runs read-only from the built-in defaults in data.ts
# and the admin panel cannot save.
MONGODB_URI=

# --- Admin panel ---
# Password required to log in at /admin. If unset, the admin panel is disabled.
ADMIN_PASSWORD=

# Optional secret used to sign the admin session cookie.
# If unset, ADMIN_PASSWORD is used. Set a long random value in production.
ADMIN_SECRET=

# --- AaqibAI chatbot ---
# Anthropic API key that powers the /AskAaqibAI assistant.
# Without it, the chat UI still works but returns a "not connected yet" message.
ANTHROPIC_API_KEY=

# --- Google Analytics (optional) ---
# Your GA4 Measurement ID (e.g. G-XXXXXXXXXX). When set, gtag is loaded on every
# page. First-party page-view analytics (the admin dashboard) work without this.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
